# ==============================================================================
# AEGISCLOUD BACKEND — Environment Configuration
# Copy this file to .env and fill in your real values before running the app.
# ==============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# Frontend URL (used in email verification/invite links — no trailing slash)
# On EC2: set this to your domain or public IP, e.g. http://yourdomain.com
APP_BASE_URL=http://localhost:5173

# ── Resend Email API ──────────────────────────────────────────────────────────
# Sign up at https://resend.com (free — 3,000 emails/month)
# Go to: Resend Dashboard → API Keys → Create Key
RESEND_API_KEY=re_YOUR_RESEND_API_KEY_HERE

# Verified sending addresses (add your domain in Resend → Domains first)
RESEND_FROM_INVITE=invite@aegiscloud.corp
RESEND_FROM_VERIFY=verify@aegiscloud.corp
RESEND_FROM_NOREPLY=noreply@aegiscloud.corp

# ── Token & Session Config ────────────────────────────────────────────────────
# Generate a secure JWT secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-a-random-64-char-string
BCRYPT_ROUNDS=12
INVITE_TOKEN_EXPIRY_HOURS=24
ORG_VERIFY_TOKEN_EXPIRY_HOURS=48
OTP_EXPIRY_MINUTES=10

# ── Demo ──────────────────────────────────────────────────────────────────────
DEFAULT_DEMO_PASSWORD=Demo@Aegis2026!

# ── AWS Configuration ─────────────────────────────────────────────────────────
# On EC2: do NOT set AWS keys here — attach an IAM Role to your EC2 instance instead.
# The AWS SDK will automatically pick up the IAM Role credentials.
# Locally: make sure your AWS CLI is configured (aws configure)
AWS_REGION=eu-north-1
AWS_S3_EVIDENCE_BUCKET=your-s3-bucket-name-here
