# ==============================================================================
# AEGISCLOUD — PRODUCTION ENVIRONMENT TEMPLATE (.env.example)
# Copy this file to .env for local development or EC2 deployment.
# All API and SSO routes use PATH-BASED routing — no subdomains needed.
# ==============================================================================

# Branding & App Identity
VITE_APP_NAME="AegisCloud Security Incident Management Platform"
VITE_APP_SHORT_NAME="AegisCloud"
VITE_ENABLE_DEMO_MODE="true"
VITE_DEFAULT_DEMO_PASSWORD="Demo@Aegis2026!"

# REST API — path-based, relative to the same domain (Nginx proxies /api/* → Node.js :8080)
# Do NOT change this to a full URL. Keep it as a relative path.
VITE_API_BASE_URL="/api/v1"

# SSO / SAML — path-based, served from the same domain (Nginx proxies /sso/* → Node.js :8080)
# Do NOT use sso.yourdomain.com — use /sso/saml2 instead.
VITE_SAML_SSO_PROVIDER_URL="/sso/saml2"

# SOAR Webhooks — path-based, served from the same backend
VITE_SOAR_AUDIT_WEBHOOK_URL="/api/v1/webhooks/audit-stream"

# External APIs (these must remain full URLs — they are third-party services)
VITE_CLOUDFLARE_API_URL="https://api.cloudflare.com/client/v4"
VITE_AWS_SECURITY_HUB_URL="https://securityhub.eu-north-1.amazonaws.com"

# Dynamic Monitored Perimeter & Domains (display-only, not used for requests)
VITE_PRIMARY_DOMAIN="yourcompany.com"
VITE_MONITORED_DOMAINS="yourcompany.com"
VITE_MONITORED_SUBNETS="172.67.0.0/16,10.0.0.0/16,198.51.100.0/24"

# AWS Cloud Infrastructure Identifiers (display/reference only)
VITE_AWS_REGION="eu-north-1"
VITE_AWS_DYNAMODB_TABLE="AegisCloud_Incidents"
VITE_AWS_S3_EVIDENCE_BUCKET="aegiscloud-evidence-vault-eu-990a3a63"
VITE_AWS_ALB_TARGET_GROUP="alb-aegiscloud-tg-01"
VITE_AWS_CLOUDWATCH_LOG_GROUP="/aws/ec2/aegiscloud-app"

# Authentication (optional — Cognito not required for current auth flow)
VITE_COGNITO_USER_POOL_ID=""

# Security Policies
VITE_DEFENSE_IN_DEPTH_LAYERS="7"
VITE_MAX_LOGIN_ATTEMPTS="5"
VITE_MAX_FILE_SIZE_MB="25"
VITE_CLOUDFLARE_ZONE_ID="your-cf-zone-id"
