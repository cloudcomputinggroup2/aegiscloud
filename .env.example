# ==============================================================================
# AEGISCLOUD — PRODUCTION ENVIRONMENT TEMPLATE (.env.example)
# Copy this file to .env for local development or deploy to hosting provider.
# ==============================================================================

# Branding & App Identity
VITE_APP_NAME="AegisCloud Security Incident Management Platform"
VITE_APP_SHORT_NAME="AegisCloud"
VITE_ENABLE_DEMO_MODE="true"
VITE_DEFAULT_DEMO_PASSWORD="Demo@Aegis2026!"

# REST API Endpoints
VITE_API_BASE_URL="https://api.yourcompany.com/v1"
VITE_CLOUDFLARE_API_URL="https://api.cloudflare.com/client/v4"
VITE_AWS_SECURITY_HUB_URL="https://securityhub.us-east-1.amazonaws.com"

# Dynamic Monitored Perimeter & Domains
VITE_PRIMARY_DOMAIN="yourcompany.com"
VITE_MONITORED_DOMAINS="yourcompany.com,api.yourcompany.com,s3.yourcompany.com,auth.yourcompany.com"
VITE_MONITORED_SUBNETS="172.67.0.0/16,10.0.0.0/16,198.51.100.0/24"

# SOAR Playbooks & Webhooks
VITE_SOAR_AUDIT_WEBHOOK_URL="https://api.yourcompany.com/v1/webhooks/audit-stream"
VITE_PAGERDUTY_ALERT_KEY="pd_live_key_replace_me"

# AWS Cloud & Capstone Infrastructure Identifiers
VITE_AWS_REGION="us-east-1"
VITE_AWS_DYNAMODB_TABLE="IncidentsTable"
VITE_AWS_S3_EVIDENCE_BUCKET="aegiscloud-evidence-repository"
VITE_AWS_ALB_TARGET_GROUP="alb-aegiscloud-tg-01"
VITE_AWS_CLOUDWATCH_LOG_GROUP="/aws/ec2/aegiscloud-app"

# Authentication & SAML/SSO Gateway
VITE_COGNITO_USER_POOL_ID="us-east-1_AegisPool"
VITE_SAML_SSO_PROVIDER_URL="https://sso.yourcompany.com/saml2"

# Security Policies
VITE_DEFENSE_IN_DEPTH_LAYERS="7"
VITE_MAX_LOGIN_ATTEMPTS="5"
VITE_MAX_FILE_SIZE_MB="25"
